{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/students/([^/]+)", "dest": "/api/students/[id].js?id=$1" },
    { "src": "/students",         "dest": "/api/students/index.js"    },
    { "src": "/css/(.*)",         "dest": "/frontend/css/$1" },
    { "src": "/js/(.*)",          "dest": "/frontend/js/$1"  },
    { "src": "/(.*)",             "dest": "/frontend/$1"     }
  ]
}
