# Environment Variables — Student Management System
# Copy this file to .env and fill in your cloud MySQL credentials

# ─── Cloud MySQL Database (Railway / Aiven / PlanetScale) ───
DB_HOST=your-db-host.railway.app
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=student_db
DB_PORT=3306

# Set DB_SSL=true if your cloud provider requires SSL (Railway does)
DB_SSL=true
